# Anthropic Client Settings
# Never commit the actual API key. Copy this file to '.env' and populate.
# The .gitignore is pre-configured to ignore '.env' files.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# The model to invoke. Defaults to 'claude-3-5-sonnet-20241022'.
# Valid options: claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022, etc.
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
